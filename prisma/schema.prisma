generator client {
  provider = "prisma-client"
  output   = "../prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Custom fields
  resumes            Resume[]
  coverLetters       CoverLetter[]
  profilePresets     ProfilePreset[]
  jobApplications    JobApplication[]
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  usageCount         Int                @default(0)
  usageLimit         Int                @default(5)
  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?
  stripeCustomerId   String?
  password           Password?

  @@index([stripeCustomerId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  @@index([email])
  @@index([token])
}

model Education {
  id           String    @id @default(cuid())
  school       String
  degree       String
  fieldOfStudy String?
  startDate    DateTime
  endDate      DateTime?
  gpa          String?
  resume       Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId     String

  @@index([resumeId])
}

model Project {
  id           String    @id @default(cuid())
  title        String
  description  String?
  link         String?
  technologies String?
  startDate    DateTime?
  endDate      DateTime?
  resume       Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId     String

  @@index([resumeId])
}

model Resume {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  title          String          @db.VarChar(120)
  summary        String?
  contactInfo    Json?
  template       String?
  experiences    Experience[]
  skills         Skill[]
  education      Education[]
  projects       Project[]
  certifications Certification[]
  languages      Language[]
  coverLetters   CoverLetter[]
  user           User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String?

  // Tailored versions
  parentResumeId String?         @db.VarChar(36)
  tailoredFor    String?         @db.VarChar(200)
  parent         Resume?         @relation("TailoredVersions", fields: [parentResumeId], references: [id], onDelete: SetNull)
  children       Resume[]        @relation("TailoredVersions")

  // Public sharing
  isPublic        Boolean @default(false)
  publicSlug      String? @unique @db.VarChar(20)
  hideContactInfo Boolean @default(false)
  viewCount       Int     @default(0)

  // Analytics, version history, job tracking
  views           ResumeView[]
  snapshots       ResumeSnapshot[]
  jobApplications JobApplication[]

  @@index([userId])
  @@index([userId, parentResumeId])
  @@index([parentResumeId])
}

model Experience {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     String
  role        String
  startDate   DateTime
  endDate     DateTime?
  description String?
  location    String?
  resume      Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId    String

  @@index([resumeId])
}

model Skill {
  id       String  @id @default(cuid())
  name     String
  level    String?
  resume   Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId String

  @@index([resumeId])
}

model Certification {
  id       String  @id @default(cuid())
  name     String
  issuer   String
  date     String?
  resume   Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId String

  @@index([resumeId])
}

model Language {
  id          String @id @default(cuid())
  name        String
  proficiency String
  resume      Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeId    String

  @@index([resumeId])
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  TRIAL
}

model ProcessedWebhook {
  id        String   @id // Stripe event ID
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   Json
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Password {
  id        String   @id @default(cuid())
  userId    String   @unique
  email     String   @unique
  hash      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
}

model ProfilePreset {
  id        String   @id @default(cuid())
  userId    String
  label     String   @db.VarChar(100)
  fullName  String?
  headline  String?
  email     String?
  phone     String?
  address   String?
  links     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CoverLetter {
  id             String   @id @default(cuid())
  title          String
  content        String   @db.Text
  status         String   @default("draft")
  jobTitle       String?
  companyName    String?
  jobDescription String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  resume          Resume?          @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  resumeId        String?
  jobApplications JobApplication[]

  @@index([userId])
  @@index([resumeId])
}

// ─── Resume Analytics ─────────────────────────────────────────────────────────

model ResumeView {
  id       String   @id @default(cuid())
  resumeId String
  viewedAt DateTime @default(now())
  resume   Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId, viewedAt])
}

// ─── Job Tracker ──────────────────────────────────────────────────────────────

enum JobStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model JobApplication {
  id            String      @id @default(cuid())
  userId        String
  company       String
  role          String
  status        JobStatus   @default(APPLIED)
  appliedAt     DateTime    @default(now())
  jobUrl        String?
  notes         String?     @db.Text
  salary        String?
  location      String?
  resumeId      String?
  coverLetterId String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume      Resume?      @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  coverLetter CoverLetter? @relation(fields: [coverLetterId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, appliedAt])
}

// ─── Version History ──────────────────────────────────────────────────────────

model ResumeSnapshot {
  id        String   @id @default(cuid())
  resumeId  String
  data      Json
  label     String?
  createdAt DateTime @default(now())
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId, createdAt])
}
